<?xml version="1.0" encoding="UTF-8"?>
<view>
    <columns>
        <group name="general" title="general" icon="fa-solid fa-robot" numcolumns="12" valign="bottom">
            <column name="name" display="none" order="0">
                <widget type="text" fieldname="name" readonly="true" required="true"/>
            </column>
            <column name="enabled" order="100">
                <widget type="checkbox" fieldname="enabled"/>
            </column>
            <column name="default-provider" numcolumns="4" order="110">
                <widget type="select" fieldname="default_provider" required="true">
                    <values title="aiscan-provider-openai">openai</values>
                    <values title="aiscan-provider-gemini">gemini</values>
                    <values title="aiscan-provider-mistral">mistral</values>
                    <values title="aiscan-provider-openai-compatible">openai-compatible</values>
                    <values title="aiscan-provider-browser-prompt">browser-prompt</values>
                </widget>
            </column>
            <column name="max-upload-size-mb" numcolumns="2" order="120">
                <widget type="number" fieldname="max_upload_size_mb" min="1" max="50" decimal="0" step="1" required="true"/>
            </column>
            <column name="request-timeout" numcolumns="2" order="130">
                <widget type="number" fieldname="request_timeout" min="10" max="300" decimal="0" step="1" required="true"/>
            </column>
            <column name="max-parallel-requests" numcolumns="2" order="135">
                <widget type="number" fieldname="max_parallel_requests" min="1" max="20" decimal="0" step="1" required="true"/>
            </column>
            <column name="allowed-extensions" numcolumns="4" order="140">
                <widget type="text" fieldname="allowed_extensions"/>
            </column>
            <column name="debug-mode" order="160">
                <widget type="checkbox" fieldname="debug_mode"/>
            </column>
        </group>
        <group name="providers" title="aiscan-providers" icon="fa-solid fa-circle-nodes" numcolumns="12">
            <column name="openai-api-key" numcolumns="4" order="100">
                <widget type="password" fieldname="openai_api_key"/>
            </column>
            <column name="openai-model" numcolumns="4" order="110">
                <widget type="text" fieldname="openai_model"/>
            </column>
            <column name="openai-base-url" numcolumns="4" order="120">
                <widget type="text" fieldname="openai_base_url"/>
            </column>
            <column name="gemini-api-key" numcolumns="6" order="200">
                <widget type="password" fieldname="gemini_api_key"/>
            </column>
            <column name="gemini-model" numcolumns="6" order="210">
                <widget type="text" fieldname="gemini_model"/>
            </column>
            <column name="mistral-api-key" numcolumns="6" order="300">
                <widget type="password" fieldname="mistral_api_key"/>
            </column>
            <column name="mistral-model" numcolumns="6" order="310">
                <widget type="text" fieldname="mistral_model"/>
            </column>
            <column name="custom-api-key" numcolumns="4" order="400">
                <widget type="password" fieldname="custom_api_key"/>
            </column>
            <column name="custom-model" numcolumns="4" order="410">
                <widget type="text" fieldname="custom_model"/>
            </column>
            <column name="custom-base-url" numcolumns="4" order="420">
                <widget type="text" fieldname="custom_base_url"/>
            </column>
        </group>
        <group name="prompt" title="extraction-prompt" icon="fa-solid fa-comment-dots" numcolumns="12">
            <column name="extraction-prompt-additions" numcolumns="12" order="100">
                <widget type="textarea" fieldname="additional_prompt" rows="6"/>
            </column>
        </group>
    </columns>
</view>
