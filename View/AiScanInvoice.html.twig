        {% endfor %}
    ];
    window.aiscanWithholdingTypes = [
        {code: '', description: '------', rate: 0},
        {% for ret in withholdingTypes %}
            {code: '{{ ret.codretencion }}', description: '{{ ret.descripcion|e('js') }}', rate: {{ ret.porcentaje }}},
        {% endfor %}
    ];
